# =====================================================================
# テスト用 read-only secrets の雛形(AppTest スモークテスト専用)
# =====================================================================
# この .example ファイルは「構造の見本」であり、値はすべてダミーです。
#
# 【谷内さんの手動配置手順】
# 1. このファイルを同じディレクトリにコピーし、拡張子 .example を外す:
#      cp .streamlit/secrets.readonly.toml.example .streamlit/secrets.readonly.toml
# 2. 下記のダミー値を、Supabase で作成した read-only ユーザー
#    (event_app_readonly)の接続情報に置き換える。
# 3. 実ファイル .streamlit/secrets.readonly.toml は .gitignore 済みなので
#    絶対にコミットされない(本番 secrets.toml と同様の扱い)。
#
# 【重要・安全設計】
# - DB_URL のユーザー部は必ず event_app_readonly にすること。
#   テストは起動時に SELECT current_user で接続ユーザーを検証し、
#   event_app_readonly 以外なら全テストを即失敗させる(誤って書き込み可能
#   ユーザーで走らないための安全弁)。
# - URL / KEY は Supabase Storage 用。スモークテストは Storage へ書き込まないが、
#   database.py が import 時に create_client で参照するため形式上必要。
#   read-only 運用に合わせ anon(公開)キー等の最小権限キーを推奨。
# =====================================================================

[supabase]
# PostgreSQL 接続文字列。ユーザー部を event_app_readonly にする。
# 例: postgresql://event_app_readonly:<PASSWORD>@<HOST>:5432/postgres
DB_URL = "postgresql://event_app_readonly:DUMMY_PASSWORD@DUMMY_HOST:5432/postgres"

# Supabase プロジェクトの URL(Storage クライアント用・ダミー)
URL = "https://DUMMY_PROJECT.supabase.co"

# Supabase の API キー(Storage クライアント用・ダミー。最小権限を推奨)
KEY = "DUMMY_ANON_KEY"
