# BOTTZ AI LINE Bot 環境変数(実値はコミットしない。Railway の Variables / ローカルは bot/.env)。
# ローカル: このファイルを bot/.env にコピーして実値を入れる(.env は .gitignore 済み)。

# --- Supabase(database.py が env 経由で読む。§段階0)---
# 本番 Supabase の Postgres 接続 URL(postgres:// / postgresql:// どちらでも可)。
SUPABASE_DB_URL=
# Supabase プロジェクト URL(Storage クライアント用)。
SUPABASE_URL=
# Supabase の API キー(Storage クライアント用)。
SUPABASE_KEY=

# --- LINE Messaging API(チャンネル「BOTTZ AI」)---
# チャンネルシークレット(署名検証に使用)。
LINE_CHANNEL_SECRET=
# チャンネルアクセストークン(reply / 画像DL に使用)。
LINE_CHANNEL_ACCESS_TOKEN=

# --- ガード ---
# 更新を許可する送信者(谷内さん)の userId。カンマ区切りで複数可。
OWNER_USER_IDS=
# 反応を許可するグループの groupId。カンマ区切りで複数可。空なら全グループ許可(送信者ガードは有効)。
ALLOWED_GROUP_IDS=
